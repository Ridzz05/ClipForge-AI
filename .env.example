APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Auto-Clip: SQLite durability (spec section 3) ---
DB_JOURNAL_MODE=WAL
DB_BUSY_TIMEOUT=5000
DB_SYNCHRONOUS=NORMAL

# --- Auto-Clip: ingest caps (spec section 6, resource exhaustion) ---
AUTOCLIP_MAX_SIZE_KB=2097152
AUTOCLIP_MAX_DURATION_SECONDS=10800
AUTOCLIP_INGEST_DISK=local

# --- Auto-Clip: external binaries (argument-array invocation) ---
AUTOCLIP_FFMPEG_PATH=ffmpeg
AUTOCLIP_FFPROBE_PATH=ffprobe

# --- Auto-Clip: self-hosted services (spec section 3) ---
AUTOCLIP_WHISPER_ENDPOINT=http://127.0.0.1:9000
AUTOCLIP_WHISPER_MODEL=small
AUTOCLIP_OLLAMA_ENDPOINT=http://127.0.0.1:11434
AUTOCLIP_OLLAMA_MODEL=qwen2.5:7b

# --- Auto-Clip: per-job hard timeouts (seconds) ---
AUTOCLIP_TIMEOUT_TRANSCRIBE=3600
AUTOCLIP_TIMEOUT_SCORE=900
AUTOCLIP_TIMEOUT_REFRAME=1800
AUTOCLIP_TIMEOUT_EXPORT=1800
